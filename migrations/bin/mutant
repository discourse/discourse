#!/usr/bin/env bash
# frozen_string_literal: true
#
# Run mutation testing for the migration gems.
#
# Each gem that opts in ships a `.mutant.yml` listing its pure, non-`:rails`
# subjects (mutant runs the gem's own spec suite, which excludes `:rails`
# examples, so only isolated subjects can be killed).
#
#   bin/mutant                 # all gems with a .mutant.yml
#   bin/mutant tooling         # just one gem
#   bin/mutant tooling --since main   # only subjects touched on this branch
#
# Anything after the gem name is passed straight through to `mutant run`.
#
# mutant is deliberately NOT a dependency in any gem's Gemfile -- it's a testing
# tool, not something the gems ship with. Instead we run each gem's real bundle
# with mutant layered on top via a temporary side gemfile (`eval_gemfile` reuses
# the gem's Gemfile, then adds mutant-rspec), installed and removed per run. So a
# clean checkout can run this with nothing extra committed. In CI, install the
# gem's own bundle once, then just call this script.
#
# No `-u`: this `cd`s around, and an environment `cd`/prompt hook that references
# an unset variable would abort the run under `set -u`. Our own variables are all
# assigned, so `-e` and `pipefail` are enough.
set -eo pipefail

migrations_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

gem=""
if [[ $# -gt 0 && -d "$migrations_dir/$1" ]]; then
  gem="$1"
  shift
fi

run_gem() {
  local dir="$1"
  shift
  echo "==> mutant: $(basename "$dir")"

  # Temporary gemfile that reuses the gem's real Gemfile (and thus its gemspec,
  # deps and lock) and adds mutant on top, so mutant never touches the committed
  # Gemfile. It has to live in the gem dir for `eval_gemfile`/`gemspec` to resolve.
  local gemfile="$dir/.mutant.gemfile"
  cat > "$gemfile" <<'RUBY'
# frozen_string_literal: true
eval_gemfile File.expand_path("Gemfile", __dir__)
gem "mutant-rspec"
RUBY

  local rc=0
  (
    cd "$dir" &&
      BUNDLE_GEMFILE="$gemfile" bundle install --quiet &&
      BUNDLE_GEMFILE="$gemfile" bundle exec mutant run --usage opensource "$@"
  ) || rc=$?

  rm -f "$gemfile" "$gemfile.lock"

  # Mutation testing runs deliberately-broken code. A mutant that drops a path
  # prefix (e.g. in ShardManager) makes a database write land relative to the
  # gem root instead of its intended temp dir. mutant has to run from the gem
  # dir (it discovers specs relative to the cwd), so those writes can't be
  # redirected from here -- clean them up afterwards so a run never leaves stray
  # SQLite files or shard dirs behind. Only untracked artifacts match; nothing
  # tracked is named this way.
  rm -f "$dir"/*.db "$dir"/*.db-shm "$dir"/*.db-wal
  rm -rf "$dir"/shards
  return "$rc"
}

status=0
if [[ -n "$gem" ]]; then
  run_gem "$migrations_dir/$gem" "$@" || status=$?
else
  for cfg in "$migrations_dir"/*/.mutant.yml; do
    run_gem "$(dirname "$cfg")" "$@" || status=$?
  done
fi
exit "$status"
