!/db/**/*.sql
!/spec/support/fixtures/**/*.sql

/config/upload.yml
/lib/converters/**/settings.local.yml

# converters within this directory should be ignored
/private/

/tmp/

# Each gem resolves its own lockfile for the isolated spec suite (not committed)
/*/Gemfile.lock

# mutant's per-gem incremental coverage cache
/*/.mutant/

# temporary side gemfile bin/mutant writes to run mutant without touching the
# gem's real Gemfile (normally removed after each run)
/*/.mutant.gemfile
/*/.mutant.gemfile.lock
