!/db/**/*.sql
!/spec/support/fixtures/**/*.sql

# Local settings overrides (may hold credentials); the committed files next to
# them are the templates.
/importer/config/upload.local.yml
/converters/lib/migrations/converters/**/settings.local.yml

# converters within this directory should be ignored
/private/

/tmp/

# Each gem resolves its own lockfile for the isolated spec suite (not committed)
/*/Gemfile.lock
