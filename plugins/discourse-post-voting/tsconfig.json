{
  "extends": "discourse/tsconfig-plugin",
  "include": [
    "admin/assets/javascripts/**/*",
    "assets/javascripts/**/*",
    "test/javascripts/**/*"
  ],
  "compilerOptions": {
    "paths": {
      "discourse/plugins/discourse-post-voting/*": ["./assets/javascripts/*"],
      "discourse/plugins/discourse-post-voting/admin/*": [
        "./admin/assets/javascripts/admin/*"
      ]
    }
  }
}
