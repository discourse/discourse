{
  "extends": "discourse/tsconfig-plugin",
  "include": [
    "admin/assets/javascripts/**/*",
    "assets/javascripts/**/*",
    "test/javascripts/**/*"
  ],
  "compilerOptions": {
    "paths": {
      "discourse/plugins/chat/*": ["./assets/javascripts/*"],
      "discourse/plugins/chat/admin/*": ["./admin/assets/javascripts/admin/*"]
    }
  }
}
