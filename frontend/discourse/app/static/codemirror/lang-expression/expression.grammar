@top Template { entity* }

entity { Text | Expression }

Expression { OpenExpression expressionContent* CloseExpression }

@tokens {
  Text { ![{] Text? | "{" (@eof | ![{] Text?) }
  OpenExpression[closedBy="CloseExpression"] { "{{" }
  CloseExpression[openedBy="OpenExpression"] { "}}" }
  expressionContent { unicodeChar | "}" ![}] | "\\}}" }
  unicodeChar { $[\u0000-\u007C] | $[\u007E-\u{10FFFF}] }
}

@detectDelim
