<script nonce="<%= csp_nonce_placeholder %>">
  (() => {
    document.querySelectorAll("[data-user-api-key-code-input]").forEach((root) => {
      const form = root.closest("form");
      const hiddenInput = form.querySelector("[data-user-api-key-code-value]");
      const submitButton = form.querySelector("[data-user-api-key-code-submit]");
      const error = form.querySelector("[data-user-api-key-code-error]");
      const inputs = Array.from(root.querySelectorAll("[data-code-character]"));

      if (!form || !hiddenInput || !submitButton || inputs.length === 0) {
        return;
      }

      const normalize = (value) => {
        return value.toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, inputs.length);
      };

      const syncCode = () => {
        hiddenInput.value = normalize(inputs.map((input) => input.value).join(""));

        if (hiddenInput.value.length === inputs.length && error) {
          error.hidden = true;
        }
      };

      const focusInput = (index) => {
        const input = inputs[index];

        if (input) {
          input.focus();
          input.select();
        }
      };

      const fillFrom = (startIndex, value) => {
        const characters = normalize(value).split("");

        characters.forEach((character, offset) => {
          const input = inputs[startIndex + offset];

          if (input) {
            input.value = character;
          }
        });

        syncCode();
        focusInput(Math.min(startIndex + characters.length, inputs.length - 1));
      };

      inputs.forEach((input, index) => {
        input.addEventListener("input", () => {
          const value = normalize(input.value);

          if (value.length > 1) {
            fillFrom(index, value);
            return;
          }

          input.value = value;
          syncCode();

          if (value && index < inputs.length - 1) {
            focusInput(index + 1);
          }
        });

        input.addEventListener("keydown", (event) => {
          if (event.key === "Backspace" && input.value === "" && index > 0) {
            event.preventDefault();
            inputs[index - 1].value = "";
            syncCode();
            focusInput(index - 1);
          } else if (event.key === "ArrowLeft" && index > 0) {
            event.preventDefault();
            focusInput(index - 1);
          } else if (event.key === "ArrowRight" && index < inputs.length - 1) {
            event.preventDefault();
            focusInput(index + 1);
          }
        });

        input.addEventListener("paste", (event) => {
          event.preventDefault();
          fillFrom(index, event.clipboardData.getData("text"));
        });

        input.addEventListener("focus", () => input.select());
      });

      form.addEventListener("submit", (event) => {
        syncCode();

        if (hiddenInput.value.length !== inputs.length) {
          event.preventDefault();

          if (error) {
            error.hidden = false;
          }

          const firstEmptyInput = inputs.findIndex((input) => input.value === "");
          focusInput(firstEmptyInput === -1 ? 0 : firstEmptyInput);
        }
      });

      syncCode();
    });
  })();
</script>
