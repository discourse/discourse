<%
  light_custom_splash = splash_screen_image_available?(dark: false)
  dark_mode_custom_splash = splash_screen_image_available?(dark: true)
  custom_splash = light_custom_splash || dark_mode_custom_splash

  light_splash_animated = light_custom_splash && splash_screen_image_animated?(dark: false)
  dark_mode_splash_animated = dark_mode_custom_splash && splash_screen_image_animated?(dark: true)

  selected_dark_scheme_id = dark_scheme_id
  has_dark_scheme =
    selected_dark_scheme_id.present? &&
      selected_dark_scheme_id != -1 &&
      selected_dark_scheme_id.to_i != scheme_id&.to_i
  single_scheme_splash =
    dark_color_scheme? || forced_light_mode? || forced_dark_mode? || !has_dark_scheme
  current_splash_dark = dark_color_scheme? || forced_dark_mode?
  current_custom_splash = current_splash_dark ? dark_mode_custom_splash : light_custom_splash
  current_splash_animated = current_splash_dark ? dark_mode_splash_animated : light_splash_animated
  rendered_custom_splash = single_scheme_splash ? current_custom_splash : custom_splash
%>

<section id="d-splash">
  <style>
    html {
      <%- if rendered_custom_splash %>
      overflow: hidden !important;
      <%- else %>
      overflow-y: hidden !important;
      <%- end %>
    }

    /* user picked a theme where the "regular" scheme is dark */
    <%- if dark_color_scheme? %>
      html {
        background-color: #<%= light_color_hex_for_name("secondary") %>;
      }

      #d-splash {
        --dot-color: #<%= light_color_hex_for_name("tertiary") %>;
        <%- if dark_mode_custom_splash %>
          <%- if dark_mode_splash_animated %>
          --primary: #<%= light_color_hex_for_name("primary") %>;
          --secondary: #<%= light_color_hex_for_name("secondary") %>;
          --tertiary: #<%= light_color_hex_for_name("tertiary") %>;
          <%- else %>
          --splash-bg: url("<%= splash_screen_image_data_uri(dark: true, color_scheme: :light) %>");
          --splash-image-offset: -10vh;
          <%- end %>
        <%- end %>
      }
    <%- elsif forced_light_mode? || !has_dark_scheme %>
      html {
        background-color: #<%= light_color_hex_for_name("secondary") %>;
      }

      #d-splash {
        --dot-color: #<%= light_color_hex_for_name("tertiary") %>;
        <%- if light_custom_splash %>
          <%- if light_splash_animated %>
          --primary: #<%= light_color_hex_for_name("primary") %>;
          --secondary: #<%= light_color_hex_for_name("secondary") %>;
          --tertiary: #<%= light_color_hex_for_name("tertiary") %>;
          <%- else %>
          --splash-bg: url("<%= splash_screen_image_data_uri(dark: false, color_scheme: :light) %>");
          --splash-image-offset: -10vh;
          <%- end %>
        <%- end %>
      }
    <%- elsif forced_dark_mode? %>
      html {
        background-color: #<%= dark_color_hex_for_name("secondary") %>;
      }

      #d-splash {
        --dot-color: #<%= dark_color_hex_for_name("tertiary") %>;
        <%- if dark_mode_custom_splash %>
          <%- if dark_mode_splash_animated %>
          --primary: #<%= dark_color_hex_for_name("primary") %>;
          --secondary: #<%= dark_color_hex_for_name("secondary") %>;
          --tertiary: #<%= dark_color_hex_for_name("tertiary") %>;
          <%- else %>
          --splash-bg: url("<%= splash_screen_image_data_uri(dark: true, color_scheme: :dark) %>");
          --splash-image-offset: -10vh;
          <%- end %>
        <%- end %>
      }
    <%- else %>
      /* user picked a theme a light scheme and also enabled a dark scheme */

      /* deal with light scheme first */
      @media (prefers-color-scheme: light) {
        html {
          background-color: #<%= light_color_hex_for_name("secondary") %>;
        }

        #d-splash {
          --dot-color: #<%= light_color_hex_for_name("tertiary") %>;
          <%- if light_custom_splash %>
            <%- if light_splash_animated %>
            --primary: #<%= light_color_hex_for_name("primary") %>;
            --secondary: #<%= light_color_hex_for_name("secondary") %>;
            --tertiary: #<%= light_color_hex_for_name("tertiary") %>;
            <%- else %>
            --splash-bg: url("<%= splash_screen_image_data_uri(dark: false, color_scheme: :light) %>");
            --splash-image-offset: -10vh;
            <%- end %>
          <%- end %>
        }
      }

      /* then deal with dark scheme */
      @media (prefers-color-scheme: dark) {
        html {
          background-color: #<%= dark_color_hex_for_name("secondary") %>;
        }

        #d-splash {
          --dot-color: #<%= dark_color_hex_for_name("tertiary") %>;
          <%- if dark_mode_custom_splash %>
            <%- if dark_mode_splash_animated %>
            --primary: #<%= dark_color_hex_for_name("primary") %>;
            --secondary: #<%= dark_color_hex_for_name("secondary") %>;
            --tertiary: #<%= dark_color_hex_for_name("tertiary") %>;
            <%- else %>
            --splash-bg: url("<%= splash_screen_image_data_uri(dark: true, color_scheme: :dark) %>");
            --splash-image-offset: -10vh;
            <%- end %>
          <%- end %>
        }
      }
    <%- end %>

    #d-splash {
      display: grid;
      place-items: center;
      position: absolute;
      left: 0;
      top: 0;
      width: 100vw;
      height: 100dvh;
      z-index: 1001;
    }

    #d-splash .preloader-image {
      --splash-dot-size: max(1vw, 25px);
      --splash-dot-spacing: calc(var(--splash-dot-size) * 1.5);
      position: relative;
      width: calc((var(--splash-dot-size) + var(--splash-dot-spacing)) * 5);
      height: 100dvh;
      background-size: cover;
    }

    #d-splash .preloader-image.single-custom-splash {
      width: 700px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      margin-top: var(--splash-image-offset, 0);
    }

    @media (display-mode: standalone) {
      #d-splash .preloader-image.single-custom-splash {
        transform: translateY(-5dvh);
      }
    }

    @media (width < 700px) {
      #d-splash .preloader-image.single-custom-splash {
        width: 320px;
      }
    }

    @media (width < 325px) {
      #d-splash .preloader-image.single-custom-splash {
        width: 300px;
      }
    }

    <%- unless single_scheme_splash %>
      @media (prefers-color-scheme: light) {
        #d-splash .preloader-image.light-custom-splash {
          width: 700px;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 1.5rem;
          margin-top: var(--splash-image-offset, 0);
        }
      }

      @media (prefers-color-scheme: dark) {
        #d-splash .preloader-image.dark-custom-splash {
          width: 700px;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 1.5rem;
          margin-top: var(--splash-image-offset, 0);
        }
      }

      @media (prefers-color-scheme: light) and (display-mode: standalone) {
        #d-splash .preloader-image.light-custom-splash {
          transform: translateY(-5dvh);
        }
      }

      @media (prefers-color-scheme: dark) and (display-mode: standalone) {
        #d-splash .preloader-image.dark-custom-splash {
          transform: translateY(-5dvh);
        }
      }

      @media (prefers-color-scheme: light) and (width < 700px) {
        #d-splash .preloader-image.light-custom-splash {
          width: 320px;
        }
      }

      @media (prefers-color-scheme: dark) and (width < 700px) {
        #d-splash .preloader-image.dark-custom-splash {
          width: 320px;
        }
      }

      @media (prefers-color-scheme: light) and (width < 325px) {
        #d-splash .preloader-image.light-custom-splash {
          width: 300px;
        }
      }

      @media (prefers-color-scheme: dark) and (width < 325px) {
        #d-splash .preloader-image.dark-custom-splash {
          width: 300px;
        }
      }
    <%- end %>

    @keyframes d-splash-fade-in {
      0% {
        opacity: 0;
      }
      100% {
        opacity: 1;
      }
    }

    <%- if rendered_custom_splash %>
    #d-splash .dots-container {
      position: relative;
      width: calc((var(--splash-dot-size) + var(--splash-dot-spacing)) * 5);
      height: var(--splash-dot-size);
    }

    #d-splash .dots-container {
      --splash-dot-size: max(0.7vw, 14px);
    }

    #d-splash .splash-logo-container {
      width: min(250px, 60vw);
      height: min(150px, 25vh);
    }

    #d-splash .splash-logo-container.animated {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #d-splash .splash-logo-container.static {
      background-size: contain;
      background-repeat: no-repeat;
      background-position: center;
      background-image: var(--splash-bg);
      opacity: 0.4;
      animation: d-splash-logo-pulse 3s ease-in-out infinite;
    }

    #d-splash .splash-logo-container svg {
      max-width: 100%;
      max-height: 100%;
    }

    <%- unless single_scheme_splash %>
    #d-splash .light-splash-element,
    #d-splash .dark-splash-element {
      display: none;
    }

    @media (prefers-color-scheme: light) {
      #d-splash .light-splash-element.default-dots-container,
      #d-splash .light-splash-element.dots-container,
      #d-splash .light-splash-element.splash-logo-container.static {
        display: block;
      }

      #d-splash .light-splash-element.splash-logo-container.animated {
        display: flex;
      }
    }

    @media (prefers-color-scheme: dark) {
      #d-splash .dark-splash-element.default-dots-container,
      #d-splash .dark-splash-element.dots-container,
      #d-splash .dark-splash-element.splash-logo-container.static {
        display: block;
      }

      #d-splash .dark-splash-element.splash-logo-container.animated {
        display: flex;
      }
    }
    <%- end %>

    @keyframes d-splash-logo-pulse {
      0%, 100% {
        opacity: 0.4;
      }
      25%, 65% {
        opacity: 1;
      }
    }
    <%- end %>

    .dots {
      animation-name: d-splash-loader;
      animation-timing-function: ease-in-out;
      animation-duration: 3s;
      animation-iteration-count: infinite;
      animation-delay: calc(var(--n) * 0.15s);

      position: absolute;
      top: calc(50% - var(--splash-dot-size) / 2);
      left: calc((50% - var(--splash-dot-size) / 2) + (var(--n) * var(--splash-dot-spacing)));
      transform-origin: calc((var(--splash-dot-spacing) * var(--n) * -1) + var(--splash-dot-size)/2) center;

      width: var(--splash-dot-size);
      height: var(--splash-dot-size);
      border-radius: 50%;

      background-color: var(--dot-color);
      filter: saturate(2) opacity(0.85);
      opacity: 0;
    }

    #d-splash .dots-container .dots {
      top: 0;
    }

    @keyframes d-splash-loader {
      0% {
        opacity: 0;
        transform: scale(1);
      }
      45% {
        opacity: 1;
        transform: scale(0.7);
      }
      65% {
        opacity: 1;
        transform: scale(0.7);
      }
      100% {
        opacity: 0;
        transform: scale(1);
      }
    }
  </style>

  <div
    class="preloader-image<%= " single-custom-splash" if single_scheme_splash && current_custom_splash %><%= " light-custom-splash" if !single_scheme_splash && light_custom_splash %><%= " dark-custom-splash" if !single_scheme_splash && dark_mode_custom_splash %>"
    elementtiming="discourse-splash-visible"
  >
    <%- if single_scheme_splash %>
      <%- if current_custom_splash %>
        <%- if current_splash_animated %>
          <div class="splash-logo-container animated">
            <%= splash_screen_inline_svg(dark: current_splash_dark) %>
          </div>
        <%- else %>
          <div class="splash-logo-container static"></div>
          <div class="dots-container">
            <div class="dots" style="--n:-2;"></div>
            <div class="dots" style="--n:-1;"></div>
            <div class="dots" style="--n:0;"></div>
            <div class="dots" style="--n:1;"></div>
            <div class="dots" style="--n:2;"></div>
          </div>
        <%- end %>
      <%- else %>
        <div class="dots" style="--n:-2;"></div>
        <div class="dots" style="--n:-1;"></div>
        <div class="dots" style="--n:0;"></div>
        <div class="dots" style="--n:1;"></div>
        <div class="dots" style="--n:2;"></div>
      <%- end %>
    <%- elsif rendered_custom_splash %>
      <%- if light_custom_splash %>
        <%- if light_splash_animated %>
          <div class="splash-logo-container animated light-splash-element">
            <%= splash_screen_inline_svg(dark: false) %>
          </div>
        <%- else %>
          <div class="splash-logo-container static light-splash-element"></div>
          <div class="dots-container light-splash-element">
            <div class="dots" style="--n:-2;"></div>
            <div class="dots" style="--n:-1;"></div>
            <div class="dots" style="--n:0;"></div>
            <div class="dots" style="--n:1;"></div>
            <div class="dots" style="--n:2;"></div>
          </div>
        <%- end %>
      <%- else %>
        <div class="default-dots-container light-splash-element">
          <div class="dots" style="--n:-2;"></div>
          <div class="dots" style="--n:-1;"></div>
          <div class="dots" style="--n:0;"></div>
          <div class="dots" style="--n:1;"></div>
          <div class="dots" style="--n:2;"></div>
        </div>
      <%- end %>

      <%- if dark_mode_custom_splash %>
        <%- if dark_mode_splash_animated %>
          <div class="splash-logo-container animated dark-splash-element">
            <%= splash_screen_inline_svg(dark: true) %>
          </div>
        <%- else %>
          <div class="splash-logo-container static dark-splash-element"></div>
          <div class="dots-container dark-splash-element">
            <div class="dots" style="--n:-2;"></div>
            <div class="dots" style="--n:-1;"></div>
            <div class="dots" style="--n:0;"></div>
            <div class="dots" style="--n:1;"></div>
            <div class="dots" style="--n:2;"></div>
          </div>
        <%- end %>
      <%- else %>
        <div class="default-dots-container dark-splash-element">
          <div class="dots" style="--n:-2;"></div>
          <div class="dots" style="--n:-1;"></div>
          <div class="dots" style="--n:0;"></div>
          <div class="dots" style="--n:1;"></div>
          <div class="dots" style="--n:2;"></div>
        </div>
      <%- end %>
    <%- else %>
      <div class="dots" style="--n:-2;"></div>
      <div class="dots" style="--n:-1;"></div>
      <div class="dots" style="--n:0;"></div>
      <div class="dots" style="--n:1;"></div>
      <div class="dots" style="--n:2;"></div>
    <%- end %>
  </div>

  <script nonce="<%= csp_nonce_placeholder %>">
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1"><!-- LCP candidate image ${".".repeat(5000)} --></svg>`;
    document.querySelector("#d-splash .preloader-image").style.backgroundImage = `url('data:image/svg+xml,${svg}')`
  </script>

  <noscript>
    <style>
      html {
        overflow-y: revert !important;
      }

      #d-splash {
        display: none;
      }
    </style>
  </noscript>
</section>
