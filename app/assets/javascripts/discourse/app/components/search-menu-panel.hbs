<MenuPanel
  @animationClass={{this.animationClass}}
  @panelClass="search-menu-panel {{if this.isEmpty 'empty'}}"
>
  <SearchMenu
    @onClose={{@closeSearchMenu}}
    @onLoading={{fn (mut this.loading)}}
    @isEmpty={{this.isEmpty}}
    @inlineResults={{true}}
    @autofocusInput={{true}}
  />
</MenuPanel>