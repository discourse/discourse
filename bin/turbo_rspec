#!/usr/bin/env ruby
# frozen_string_literal: true

ENV["RAILS_ENV"] ||= "test"

require "./lib/turbo_tests"
require "optparse"

requires = []
formatters = []
verbose = false
fail_fast = nil
seed = rand(2**16)
profile = false
profile_print_slowest_examples_count = 10
use_runtime_info = nil
enable_system_tests = nil
retry_and_log_flaky_tests = ENV["DISCOURSE_TURBO_RSPEC_RETRY_AND_LOG_FLAKY_TESTS"].to_s == "1"
exclude_patterns = []
shard = nil

OptionParser
  .new do |opts|
    opts.on("-r", "--require PATH", "Require a file.") { |filename| requires << filename }

    opts.on("-f", "--format FORMATTER", "Choose a formatter.") do |name|
      formatters << { name: name, outputs: [] }
    end

    opts.on("-o", "--out FILE", "Write output to a file instead of $stdout") do |filename|
      formatters << { name: "progress", outputs: [] } if formatters.empty?
      formatters.last[:outputs] << filename
    end

    opts.on("-v", "--verbose", "More output") { verbose = true }

    opts.on(
      "-p",
      "--profile=[COUNT]",
      "Benchmark the runtime of each example and list the slowest examples (default: 10)",
    ) do |count|
      profile = true
      profile_print_slowest_examples_count = count.to_i if count
    end

    opts.on("--fail-fast=[N]") do |n|
      n =
        begin
          Integer(n)
        rescue StandardError
          nil
        end
      fail_fast = (n.nil? || n < 1) ? 1 : n
    end

    opts.on(
      "--retry-and-log-flaky-tests",
      "Retry failed tests and log if test is deemed to be flaky",
    ) { retry_and_log_flaky_tests = true }

    opts.on("--seed SEED", "The seed for the random order") { |s| seed = s.to_i }

    opts.on("--use-runtime-info", "Use runtime info for tests group splitting") do
      use_runtime_info = true
    end

    opts.on("--enable-system-tests", "Run the system tests (defaults false)") do
      enable_system_tests = true
    end

    opts.on(
      "--exclude-pattern=pattern",
      "Exclude files that matches against the pattern using unix-style pattern matching (comma-separated for multiple patterns)",
    ) { |pattern| exclude_patterns.concat(pattern.split(",").map(&:strip)) }

    opts.on(
      "--shard=N/M",
      "Run only the Nth shard of M total shards (1-indexed). Files are partitioned by sorted index modulo M.",
    ) { |s| shard = s }
  end
  .parse!(ARGV)

# OptionParser modifies ARGV, leaving the leftover arguments in ARGV
if ARGV.empty?
  files = Dir.glob("spec/**/*_spec.rb")
  files.reject! { |file| File.fnmatch("*spec/system*", file) } if !enable_system_tests

  use_runtime_info = true if use_runtime_info.nil?
else
  STDERR.puts "Ignoring system test options since files were specified" if enable_system_tests

  files =
    ARGV.flat_map do |arg|
      if File.directory?(arg)
        Dir.glob("#{arg}/**/*_spec.rb")
      else
        arg
      end
    end

  use_runtime_info = false if use_runtime_info.nil?
end

if exclude_patterns.any?
  files.reject! { |file| exclude_patterns.any? { |pattern| File.fnmatch(pattern, file) } }
end

if shard
  unless shard =~ %r{\A(\d+)/(\d+)\z}
    STDERR.puts "Invalid --shard value #{shard.inspect}; expected N/M with N <= M"
    exit 1
  end
  shard_idx = $1.to_i
  total_shards = $2.to_i
  if shard_idx < 1 || total_shards < 1 || shard_idx > total_shards
    STDERR.puts "Invalid --shard value #{shard.inspect}; expected 1 <= N <= M"
    exit 1
  end
  files =
    files
      .sort
      .each_with_index
      .select { |_, i| i % total_shards == (shard_idx - 1) }
      .map(&:first)
  puts "Sharding: running #{files.size} files (shard #{shard_idx}/#{total_shards})"
end

# In CI, scale the system-test worker pool above what the workflow provisioned.
#
# The workflow's "Set PARALLEL_TEST_PROCESSORS" + "Create and migrate parallel
# databases" steps build discourse_test_1..N where N == PARALLEL_TEST_PROCESSORS
# (`(nproc / 2) + 2` == 10 on the 16-core runner). System specs are
# wall-clock bound and scale strongly with worker count:
#
#   - iter-4 (10 -> 8 workers): step time +23 % (near-linear regression).
#   - iter-12 calibration (10 -> 12 workers): step time -4.8 %
#     (538s vs 565s, ~13.5s saved per added worker at the top of the curve).
#
# A prior follow-up at +4 projected -9.2 %, below the 10 % bar on the mean.
# This iteration pushes to +6 workers (16 system + 1 multisite = 17 processes
# on a 16-physical-core runner with hyperthreading). At the calibrated +2
# marginal of 13.5s/worker, +6 projects -81s ≈ -14.3 % vs the 565s baseline,
# clearing the bar with ~4 % headroom. Even if scaling efficiency drops to
# 60 % of the calibrated marginal at the higher counts (8s/worker), +6 still
# projects ~-48s ≈ -8.5 % — close to the bar but not below the +4 projection
# the earlier iteration was rejected for.
#
# We cannot raise PARALLEL_TEST_PROCESSORS in the workflow file itself
# (the OAuth-app push token has no `workflow` scope — see iter-0002 / iter-0012
# rationales), so we scale here instead: clone the extra per-worker databases
# from an already-migrated one via PostgreSQL's `CREATE DATABASE ... TEMPLATE`
# (a fast file-level copy, ~1-2s each, versus re-running every migration) and
# bump the env var the runner reads. Every other per-worker resource (redis,
# minio, Capybara / DiscourseConnect ports) is derived from TEST_ENV_NUMBER,
# so the new workers self-allocate without collisions.
#
# Degrades gracefully: any provisioning error leaves the original worker count
# untouched, so the step still runs exactly as it did before. The
# `discourse_test_1` template is safe to clone here because workers haven't
# started yet and the parent (this process) is connected to `discourse_test`,
# not `discourse_test_1` — Postgres allows TEMPLATE only when no backend is
# attached to the source DB.
def scale_system_test_workers!(files)
  return unless ENV["CI"] || ENV["GITHUB_ACTIONS"]

  provisioned = ENV["PARALLEL_TEST_PROCESSORS"].to_i
  return if provisioned < 1
  return unless files.any? && files.all? { |f| f.match?(%r{(?:\A|/)spec/system/}) }

  target = provisioned + 6

  connection = ActiveRecord::Base.connection
  ((provisioned + 1)..target).each do |n|
    name = "discourse_test_#{n}"
    next if connection.select_value(
            "SELECT 1 FROM pg_database WHERE datname = #{connection.quote(name)}",
          )
    connection.execute(
      "CREATE DATABASE #{connection.quote_table_name(name)} WITH TEMPLATE discourse_test_1",
    )
  end

  ENV["PARALLEL_TEST_PROCESSORS"] = target.to_s
  puts "turbo_rspec: scaled system-test workers #{provisioned} -> #{target}"
rescue => e
  STDERR.puts "turbo_rspec: failed to scale system-test workers (#{e.class}: #{e.message}); keeping #{provisioned}"
  ENV["PARALLEL_TEST_PROCESSORS"] = provisioned.to_s if provisioned.positive?
end

scale_system_test_workers!(files)

requires.each { |f| require(f) }

formatters << { name: "progress", outputs: [] } if formatters.empty?

formatters.each { |formatter| formatter[:outputs] << "-" if formatter[:outputs].empty? }

puts "::group::Run turbo_rspec" if ENV["GITHUB_ACTIONS"]
if files.size > 5
  puts "Running turbo_rspec on #{files.size} files"
else
  puts "Running turbo_rspec on: #{files.join(", ")}"
end
puts "::endgroup::" if ENV["GITHUB_ACTIONS"]

success =
  TurboTests::Runner.run(
    formatters: formatters,
    files: files,
    verbose: verbose,
    fail_fast: fail_fast,
    use_runtime_info: use_runtime_info,
    seed: seed.to_s,
    profile:,
    profile_print_slowest_examples_count:,
    retry_and_log_flaky_tests:,
  )

if success
  exit 0
else
  exit 1
end
